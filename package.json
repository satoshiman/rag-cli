{
  "name": "rag-cli",
  "version": "0.1.0",
  "description": "Local-first RAG CLI application for personal documentation",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "rag": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "rag",
    "cli",
    "semantic-search",
    "vector-search",
    "local-llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@upstash/vector": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "glob": "^10.3.10",
    "langchain": "^0.1.0",
    "markdown-it": "^14.0.0",
    "ora": "^5.4.1",
    "pdfjs-dist": "^4.0.379",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}